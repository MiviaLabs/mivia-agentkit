version: "1"
profile: {{ .Profile }}
template_version: {{ .Version }}
project:
  name: {{ .Project.Name }}
adapters:
{{- range $name, $enabled := .Adapters }}
  {{ $name }}:
    enabled: {{ $enabled }}
    role: {{ if eq $name "copilot" }}guidance{{ else }}orchestrable{{ end }}
{{- if eq $name "crush" }}
    # model: ollama/qwen3:14b
{{- end }}
{{- end }}
routing:
  default_producer: {{ .Routing.DefaultProducer }}
  default_reviewers:
{{- range .Routing.DefaultReviewers }}
    - {{ . }}
{{- end }}
  consensus:
    mode: majority
    tie_breaker: strict
    min_reviewers: {{ .Routing.MinReviewers }}
  on_review_fail: iterate
  max_iterations: 3
governance:
  provider: noop
  audit_log: .ai/audit.jsonl
# Supervised audit-repair campaigns are disabled by default.
# Enable only with independent auditor/confirmer adapters and explicit operator launch:
#   mivia-agent campaign run --repo . --campaign deep-bug-audit-repair --json
# Do not enable from hooks, CI, or prompt substring matching.
campaigns:
  deep-bug-audit-repair:
    enabled: false
    clean_pass_threshold: 2
    max_cycles: 10
    max_duration: 2h
    max_repair_attempts: 3
    no_progress_threshold: 2
    commit_enabled: false
    on_exhausted: fail
global:
  layer: ~/.agents
  merge: project_wins
