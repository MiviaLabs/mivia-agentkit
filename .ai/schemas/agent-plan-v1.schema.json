{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mivialabs.local/schemas/agent-plan-v1.schema.json",
  "title": "Mivia Agent Plan v1",
  "type": "object",
  "required": [
    "PlanFormat",
    "plan_id",
    "version",
    "baseline_commit",
    "scope",
    "source_evidence",
    "external_docs",
    "dag",
    "gaps",
    "correction_log",
    "stop_conditions"
  ],
  "properties": {
    "PlanFormat": {
      "const": "mivia-agent-plan/v1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "const": 1
    },
    "baseline_commit": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": ["in", "out", "files"]
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1
    },
    "external_docs": {
      "type": "array"
    },
    "dag": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "skill",
              "agent",
              "depends_on",
              "task_dir",
              "files_read",
              "files_edit",
              "allowed_mcp_tools",
              "tests",
              "verifiers",
              "mutation",
              "outputs"
            ],
            "properties": {
              "task_dir": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "minItems": 1
    },
    "correction_log": {
      "type": "array",
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false
}
