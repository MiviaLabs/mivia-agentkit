{
  "PlanFormat": "mivia-agent-plan/v1",
  "plan_id": "<short-stable-id>",
  "version": 1,
  "baseline_commit": "<branch/commit>",
  "scope": {
    "in": ["<paths/packages/features in scope>"],
    "out": ["<explicitly excluded paths/packages/features>"],
    "files": ["<files likely read or edited>"]
  },
  "source_evidence": [
    {
      "path": "<repo path>",
      "reason": "<why it was read>",
      "checked_at": "YYYY-MM-DD"
    }
  ],
  "external_docs": [
    {
      "url": "<official/current URL or none>",
      "reason": "<why current external behavior matters>",
      "checked_at": "YYYY-MM-DD"
    }
  ],
  "dag": {
    "nodes": [
      {
        "id": "<unique-node-id>",
        "title": "<short title>",
        "skill": "agent-dag-planner|agent-plan-implementer|deep-bug-audit|test-coverage-audit|adversarial-test-review|airtight-feature-delivery",
        "agent": "codex|claude|agents|manual",
        "depends_on": [],
        "files_read": ["<repo path>"],
        "files_edit": ["<repo path>"],
        "allowed_mcp_tools": ["<server.tool or none>"],
        "tests": ["<test file>::<test name>"],
        "verifiers": ["<exact command>"],
        "mutation": "<guard mutation that must fail a named test>",
        "outputs": ["<repo path>"]
      }
    ]
  },
  "gaps": [
    {
      "id": "none",
      "status": "closed",
      "severity": "none",
      "description": "none",
      "required_fix": "none",
      "required_test": "none"
    }
  ],
  "correction_log": [
    {
      "source": "<existing plan/doc/source>",
      "gap": "<what was stale, missing, or too vague>",
      "correction": "<what the planner corrected>"
    }
  ],
  "stop_conditions": ["python3 scripts/validate_agent_plan.py <plan>"]
}
