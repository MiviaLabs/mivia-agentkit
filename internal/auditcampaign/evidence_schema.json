{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mivia-agent-campaign-evidence/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "campaign_run",
    "cycle",
    "baseline_head",
    "finding_fingerprint",
    "disposition",
    "finding_claim",
    "path_hints",
    "changed_path_ids",
    "verifier_ref",
    "progress"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["mivia-agent-campaign-evidence/v1"]
    },
    "campaign_run": { "type": "string" },
    "cycle": { "type": "integer", "minimum": 0 },
    "baseline_head": { "type": "string" },
    "finding_fingerprint": { "type": "string" },
    "disposition": {
      "type": "string",
      "enum": ["candidate", "confirmed", "duplicate", "fixed", "rejected", ""]
    },
    "finding_claim": { "type": "string", "maxLength": 240 },
    "path_hints": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "maxLength": 200 }
    },
    "changed_path_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verifier_ref": { "type": "string" },
    "progress": { "type": "integer" }
  }
}
