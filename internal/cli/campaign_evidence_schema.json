{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mivia-agent-campaign-evidence/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "campaign_run", "cycle", "baseline_head"],
  "properties": {
    "schema": {
      "type": "string",
      "enum": ["mivia-agent-campaign-evidence/v1"]
    },
    "campaign_run": { "type": "string", "minLength": 1 },
    "cycle": { "type": "integer", "minimum": 0 },
    "baseline_head": { "type": "string", "minLength": 1 },
    "finding_fingerprint": { "type": "string" },
    "disposition": {
      "type": "string",
      "enum": ["candidate", "confirmed", "duplicate", "fixed", "rejected"]
    },
    "changed_path_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verifier_ref": { "type": "string" },
    "progress": { "type": "integer" },
    "token_source": {
      "type": "string",
      "enum": ["provider", "unavailable"]
    },
    "timing_source": {
      "type": "string",
      "enum": ["runtime", "NOT_MEASURED"]
    },
    "measured_elapsed_ms": { "type": "integer", "minimum": 0 },
    "provider_tokens": { "type": "integer", "minimum": 0 }
  }
}
